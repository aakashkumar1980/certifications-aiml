								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"question\": \"Which campaign has the highest enrollment?\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/ask",
							"host": ["{{baseUrl}}"],
							"path": ["ask"]
						}
					}
				},
				{
					"name": "Ask SQL Query",
					"request": {
